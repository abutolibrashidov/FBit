# Bot Configuration
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=12345678,87654321

# App Configuration
APP_NAME="Telegram Social Platform"
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bot_db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Modules Configuration
ANONYMOUS_LINK_PREFIX=https://t.me/your_bot?start=msg_
REFERRAL_LINK_PREFIX=https://t.me/your_bot?start=ref_

# Local Settings
LOG_LEVEL=INFO
